# Telegram bot is optional; API starts without it.
TELEGRAM_BOT_TOKEN=

# GigaChat is required for text/NL filtering and schema enrichment.
GIGACHAT_CREDENTIALS=
GIGACHAT_MODEL=GigaChat-2-Max
LANGUAGE=ru
MAX_RESULTS=10
CAT_THRESHOLD=50

# API
API_HOST=0.0.0.0
API_PORT=8000
STORAGE_DIR=/data/filter-platform

# Redis
REDIS_URL=redis://redis:6379/0
SCHEMA_CACHE_TTL_SECONDS=604800
DIALOG_TTL_SECONDS=86400
DIALOG_HISTORY_LIMIT=10

# CLIP visual search
CLIP_MODEL=ViT-B-32
CLIP_PRETRAINED=laion2b_s34b_b79k
HYBRID_ALPHA=0.5

# CLIP / Hugging Face
CLIP_BUILD_ON_UPLOAD_DEFAULT=false
HF_HUB_DISABLE_XET=1
HF_HOME=/data/huggingface
TORCH_HOME=/data/torch
